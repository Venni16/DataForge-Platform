# ── Supabase (optional) ──────────────────────────────────────────────────────
# If left blank, the backend falls back to local JSON file storage automatically.
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# ── Data Engine ───────────────────────────────────────────────────────────────
DATA_ENGINE_URL=http://localhost:8000

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
